{
  "compilerOptions": {
    "target": "es2022",                                  
    "module": "commonjs",                                
    "moduleResolution": "node",
    "esModuleInterop": true,                             
    "resolveJsonModule": true,                                 
    "strict": true,                                      
    "noImplicitAny": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,            
    "skipLibCheck": true                               
  }
}